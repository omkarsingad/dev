apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: appfortelemetry
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/omkarsingad/modules.git     # ← Plain URL
    targetRevision: main
    path: apps/appfortelemetry
  destination:
    server: https://kubernetes.default.svc                  # ← Plain URL
    namespace: observability
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
